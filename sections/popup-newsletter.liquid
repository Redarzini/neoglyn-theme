{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'newsletter-section.css' | asset_url | stylesheet_tag }}

<style>
  .popup-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(var(--color-foreground), 0.5);
    backdrop-filter: blur(4px);
    z-index: 999;
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .popup-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .popup-content {
    background: rgb(var(--color-background));
    padding: 4rem;
    border-radius: 12px;
    position: relative;
    max-width: 500px;
    width: 90%;
    text-align: center;
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    transform: translateY(20px);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .popup-overlay.active .popup-content {
    transform: translateY(0);
  }

  .popup-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: none;
    border: none;
    cursor: pointer;
    color: rgb(var(--color-foreground));
  }
</style>

<div id="NeoglynPopup" class="popup-overlay color-{{ section.settings.color_scheme }} gradient">
  <div class="popup-content">
    <button class="popup-close" id="ClosePopup" aria-label="Close">
      <span class="svg-wrapper" style="width: 24px;">{{ 'icon-close.svg' | inline_asset_content }}</span>
    </button>
    
    <h2 class="h1" style="margin-bottom: 1rem;">Join The Club.</h2>
    <p style="margin-bottom: 2rem; font-size: 1.6rem;">Get 15% off your first Anti-Gravity microcurrent device and exclusive access to clinical insights.</p>

    {% form 'customer', class: 'newsletter-form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="newsletter-form__field-wrapper">
        <div class="field">
          <input
            id="PopupNewsletterForm--{{ section.id }}"
            type="email"
            name="contact[email]"
            class="field__input"
            value="{{ form.email }}"
            aria-required="true"
            aria-label="Email address"
            placeholder="Enter your email"
            required
          >
          <label class="field__label" for="PopupNewsletterForm--{{ section.id }}">
            Email address
          </label>
          <button
            type="submit"
            class="newsletter-form__button field__button"
            name="commit"
            id="PopupSubscribe"
            aria-label="Subscribe"
          >
            <span class="svg-wrapper">
              {{- 'icon-arrow.svg' | inline_asset_content -}}
            </span>
          </button>
        </div>
        {%- if form.errors -%}
          <small class="newsletter-form__message form__message" id="PopupNewsletter-error--{{ section.id }}">
            <span class="svg-wrapper">
              {{- 'icon-error.svg' | inline_asset_content -}}
            </span>
            {{- form.errors.translated_fields.email | capitalize }}
            {{ form.errors.messages.email -}}
          </small>
        {%- endif -%}
      </div>
      {%- if form.posted_successfully? -%}
        <h3
          class="newsletter-form__message newsletter-form__message--success form__message"
          id="PopupNewsletter-success--{{ section.id }}"
          tabindex="-1"
          autofocus
        >
          <span class="svg-wrapper">
            {{- 'icon-success.svg' | inline_asset_content -}}
          </span>
          Thanks for subscribing! Check your email for your 15% code.
        </h3>
      {%- endif -%}
    {% endform %}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Check if popup has already been shown
    if (!sessionStorage.getItem('neoglyn_popup_shown')) {
      setTimeout(() => {
        const popup = document.getElementById('NeoglynPopup');
        if(popup) {
          popup.classList.add('active');
        }
      }, 5000); // Show after 5 seconds
    }

    const closeBtn = document.getElementById('ClosePopup');
    if(closeBtn) {
      closeBtn.addEventListener('click', (e) => {
        e.preventDefault();
        document.getElementById('NeoglynPopup').classList.remove('active');
        sessionStorage.setItem('neoglyn_popup_shown', 'true');
      });
    }
  });
</script>

{% schema %}
{
  "name": "Popup Newsletter",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-2"
    }
  ],
  "presets": [
    {
      "name": "Popup Newsletter"
    }
  ]
}
{% endschema %}
