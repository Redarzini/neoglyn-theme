{{ 'component-neoglyn-layout.css' | asset_url | stylesheet_tag }}

<footer class="neoglyn-footer">
  <div class="neoglyn-footer__grid">
    <div class="neoglyn-footer__brand">
      <a href="{{ routes.root_url }}" class="neoglyn-header__logo" style="color: var(--color-primary);">
        <span class="material-symbols-outlined neoglyn-header__logo-icon">auto_awesome</span>
        <h2 class="neoglyn-header__logo-text">{{ shop.name }}</h2>
      </a>
      <p class="neoglyn-footer__desc">{{ section.settings.store_description }}</p>
      
      {%- if section.settings.show_social -%}
      <div class="neoglyn-footer__social">
        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" class="neoglyn-footer__social-link" target="_blank">
            <span class="material-symbols-outlined">photo_camera</span>
          </a>
        {%- endif -%}
        {%- if settings.social_facebook_link != blank -%}
           <a href="{{ settings.social_facebook_link }}" class="neoglyn-footer__social-link" target="_blank">
            <span class="material-symbols-outlined">public</span>
          </a>
        {%- endif -%}
      </div>
      {%- endif -%}
    </div>

    {%- for block in section.blocks -%}
      {%- if block.type == 'link_list' -%}
        <div>
          <h4 class="neoglyn-footer__heading">{{ block.settings.heading | default: block.settings.menu.title }}</h4>
          <ul class="neoglyn-footer__list">
            {%- for link in block.settings.menu.links -%}
              <li><a href="{{ link.url }}" class="neoglyn-footer__link">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="neoglyn-footer__bottom">
    <div class="neoglyn-footer__copyright">
      &copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All rights reserved.
    </div>

    {%- if section.settings.payment_enable -%}
      <div class="neoglyn-footer__payment">
        <span class="material-symbols-outlined" style="font-size: 28px;">payments</span>
        <span class="material-symbols-outlined" style="font-size: 28px;">credit_card</span>
        <span class="material-symbols-outlined" style="font-size: 28px;">account_balance_wallet</span>
      </div>
    {%- endif -%}
  </div>
</footer>

{% schema %}
{
  "name": "Neoglyn Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "store_description",
      "label": "Store Description",
      "default": "Neoglyn is a pioneer in professional-grade beauty technology, bringing the salon experience directly to your vanity."
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social media icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "label": "Show payment icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu Column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ]
}
{% endschema %}
