{{ 'neoglyn-checkout.css' | asset_url | stylesheet_tag }}

<div class="neoglyn-checkout">
  <div class="page-width neoglyn-checkout__container">
    
    <!-- Left Column: Primary Content -->
    <main class="neoglyn-checkout__main">
      <nav class="neoglyn-checkout__breadcrumbs">
        <a href="{{ routes.cart_url }}" class="neoglyn-checkout__breadcrumb-link">Cart</a>
        <span class="material-symbols-outlined neoglyn-checkout__breadcrumb-separator">chevron_right</span>
        <span class="neoglyn-checkout__breadcrumb-link">Information</span>
        <span class="material-symbols-outlined neoglyn-checkout__breadcrumb-separator">chevron_right</span>
        <span class="neoglyn-checkout__breadcrumb-current">Payment</span>
      </nav>

      <div class="neoglyn-checkout__panel">
        <div class="neoglyn-checkout__header">
          <h1 class="neoglyn-checkout__title">Payment Method</h1>
          <p class="neoglyn-checkout__subtitle">
            <span class="material-symbols-outlined fill-1">lock</span>
            All transactions are secure and encrypted for your safety.
          </p>
        </div>

        <!-- Note: This is an aesthetic mockup of the checkout. The real flow requires Shopify Plus to modify checkout.liquid directly. -->
        <div class="neoglyn-checkout__methods">
          
          <div class="neoglyn-checkout__method neoglyn-checkout__method--active">
            <div class="neoglyn-checkout__method-header">
              <div class="neoglyn-checkout__radio"></div>
              <div class="neoglyn-checkout__method-content">
                <div class="neoglyn-checkout__method-info">
                  <p class="neoglyn-checkout__method-title">Credit Card</p>
                  <p class="neoglyn-checkout__method-desc">Visa, Mastercard, AMEX</p>
                </div>
                <span class="material-symbols-outlined neoglyn-checkout__method-icon">credit_card</span>
              </div>
            </div>
            <div class="neoglyn-checkout__method-body">
              <fieldset class="neoglyn-checkout__fieldset">
                <div class="neoglyn-checkout__field">
                  <input type="text" class="neoglyn-checkout__input" placeholder="Card number" aria-label="Card number" disabled>
                </div>
                <div class="neoglyn-checkout__field-group">
                  <div class="neoglyn-checkout__field">
                    <input type="text" class="neoglyn-checkout__input" placeholder="MM / YY" aria-label="Expiration date" disabled>
                  </div>
                  <div class="neoglyn-checkout__field">
                    <input type="text" class="neoglyn-checkout__input" placeholder="CVV" aria-label="Security code" disabled>
                  </div>
                </div>
              </fieldset>
            </div>
          </div>

          <div class="neoglyn-checkout__method">
            <div class="neoglyn-checkout__method-header">
              <div class="neoglyn-checkout__radio"></div>
              <div class="neoglyn-checkout__method-content">
                <div class="neoglyn-checkout__method-info">
                  <p class="neoglyn-checkout__method-title">PayPal</p>
                  <p class="neoglyn-checkout__method-desc">Pay via your PayPal account</p>
                </div>
                <span class="material-symbols-outlined neoglyn-checkout__method-icon">payments</span>
              </div>
            </div>
          </div>

          <div class="neoglyn-checkout__method">
            <div class="neoglyn-checkout__method-header">
              <div class="neoglyn-checkout__radio"></div>
              <div class="neoglyn-checkout__method-content">
                <div class="neoglyn-checkout__method-info">
                  <p class="neoglyn-checkout__method-title">Apple Pay</p>
                  <p class="neoglyn-checkout__method-desc">Quick pay with Apple Wallet</p>
                </div>
                <span class="material-symbols-outlined neoglyn-checkout__method-icon">contactless</span>
              </div>
            </div>
          </div>

        </div>

        <div class="neoglyn-checkout__submit-wrapper">
          <form action="{{ routes.cart_url }}" method="post" id="cart">
             <button type="submit" name="checkout" class="neoglyn-checkout__submit" form="cart">Complete Order</button>
          </form>
        </div>
      </div>

      <div class="neoglyn-checkout__trust">
        <div class="neoglyn-checkout__trust-item">
          <span class="material-symbols-outlined">verified_user</span>
          <span>Secure Checkout</span>
        </div>
        <div class="neoglyn-checkout__trust-item">
          <span class="material-symbols-outlined fill-1">shield_lock</span>
          <span>SSL Encrypted</span>
        </div>
        <div class="neoglyn-checkout__trust-item">
          <span class="material-symbols-outlined">published_with_changes</span>
          <span>30-Day Guarantee</span>
        </div>
      </div>
    </main>

    <!-- Right Column: Order Summary -->
    <aside class="neoglyn-checkout__sidebar">
      <div class="neoglyn-checkout__summary">
        <h3 class="neoglyn-checkout__summary-title">Order Summary</h3>
        
        <div class="neoglyn-checkout__cart-items">
          {%- if cart.item_count > 0 -%}
            {%- for item in cart.items -%}
              <div class="neoglyn-checkout__cart-item">
                <div class="neoglyn-checkout__item-img-wrapper">
                  {%- if item.image -%}
                    {{ item.image | image_url: width: 200 | image_tag: class: 'neoglyn-checkout__item-img' }}
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'neoglyn-checkout__item-img' }}
                  {%- endif -%}
                  <span class="neoglyn-checkout__item-qty">{{ item.quantity }}</span>
                </div>
                <div class="neoglyn-checkout__item-info">
                  <p class="neoglyn-checkout__item-title">{{ item.product.title | escape }}</p>
                  {%- if item.product.has_only_default_variant == false or item.properties.size != 0 -%}
                    <p class="neoglyn-checkout__item-variant">
                      {%- for option in item.options_with_values -%}
                        {{ option.value }}{%- unless forloop.last -%} / {%- endunless -%}
                      {%- endfor -%}
                    </p>
                  {%- endif -%}
                  <p class="neoglyn-checkout__item-price">{{ item.final_line_price | money }}</p>
                </div>
              </div>
            {%- endfor -%}
          {%- else -%}
             <div class="neoglyn-checkout__cart-item">
                <div class="neoglyn-checkout__item-info">
                  <p class="neoglyn-checkout__item-title">Your cart is empty.</p>
                </div>
              </div>
          {%- endif -%}
        </div>

        <div class="neoglyn-checkout__totals">
          <div class="neoglyn-checkout__total-line">
            <span>Subtotal</span>
            <span>{{ cart.items_subtotal_price | money }}</span>
          </div>
          <div class="neoglyn-checkout__total-line">
            <span>Shipping</span>
            <span class="neoglyn-checkout__total-line--highlight">Calculated at next step</span>
          </div>
          <div class="neoglyn-checkout__total-line">
            <span>Taxes</span>
            <span>Est. {{ 0 | money }}</span>
          </div>
        </div>

        <div class="neoglyn-checkout__final">
          <span class="neoglyn-checkout__final-label">Total</span>
          <div class="neoglyn-checkout__final-price">
            <span class="neoglyn-checkout__final-currency">{{ cart.currency.iso_code }}</span>
            <span class="neoglyn-checkout__final-amount">{{ cart.total_price | money }}</span>
          </div>
        </div>

        <div class="neoglyn-checkout__discount">
          <div class="neoglyn-checkout__discount-form">
            <span class="material-symbols-outlined neoglyn-checkout__discount-icon">redeem</span>
            <input type="text" class="neoglyn-checkout__discount-input" placeholder="Discount code">
            <button class="neoglyn-checkout__discount-btn">Apply</button>
          </div>
        </div>
      </div>
    </aside>

  </div>
</div>

<script>
  // Simple script to toggle active class visually for the custom radio aesthetic
  document.addEventListener('DOMContentLoaded', () => {
    const methods = document.querySelectorAll('.neoglyn-checkout__method');
    methods.forEach(method => {
      method.addEventListener('click', () => {
        methods.forEach(m => m.classList.remove('neoglyn-checkout__method--active'));
        method.classList.add('neoglyn-checkout__method--active');
      });
    });
  });
</script>

{% schema %}
{
  "name": "Neoglyn Custom Checkout",
  "tag": "section",
  "settings": [
    {
       "type": "paragraph",
       "content": "Note: Modifying the true checkout requires Shopify Plus. This acts as a visual representation or custom cart step."
    }
  ],
  "presets": [
    {
      "name": "Neoglyn Custom Checkout"
    }
  ]
}
{% endschema %}
