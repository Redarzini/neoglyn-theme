{%- style -%}
.hero-v2-{{ section.id }} {
  position: relative;
  width: 100%;
  height: 100vh;
  min-height: 600px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background-color: var(--color-primary);
}

.hero-v2__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 1;
}

.hero-v2__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, var(--color-primary), transparent 60%);
  z-index: 2;
  opacity: 0.8;
}

.hero-v2__content {
  position: relative;
  z-index: 10;
  text-align: center;
  max-width: 800px;
  padding: 0 2rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rem;
}

.hero-v2__title {
  font-family: var(--font-heading-family);
  font-size: clamp(3rem, 6vw, 5rem);
  font-weight: 900;
  color: var(--color-foreground);
  line-height: 1.1;
  letter-spacing: -0.03em;
  margin: 0;
  text-transform: uppercase;
}

.hero-v2__text {
  font-size: clamp(1.125rem, 2vw, 1.25rem);
  color: var(--color-text-muted);
  max-width: 600px;
  margin: 0;
  font-weight: 300;
  line-height: 1.6;
}

.hero-v2__actions {
  display: flex;
  gap: 1.5rem;
  margin-top: 1rem;
}

@media screen and (max-width: 749px) {
  .hero-v2__actions {
    flex-direction: column;
    width: 100%;
  }
  .hero-v2__actions .btn-primary, .hero-v2__actions .btn-secondary {
    width: 100%;
  }
}
{%- endstyle -%}

<section class="hero-v2-{{ section.id }}">
  {%- if section.settings.video_url != blank -%}
    <video autoplay muted loop playsinline class="hero-v2__bg">
      <source src="{{ section.settings.video_url }}" type="video/mp4">
    </video>
  {%- elsif section.settings.image != blank -%}
    {{ section.settings.image | image_url: width: 2000 | image_tag: class: 'hero-v2__bg' }}
  {%- else -%}
    {{ 'lifestyle-1' | placeholder_svg_tag: 'hero-v2__bg' }}
  {%- endif -%}

  <div class="hero-v2__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}"></div>

  <div class="hero-v2__content">
    <h1 class="hero-v2__title">{{ section.settings.heading }}</h1>
    
    {%- if section.settings.text != blank -%}
      <p class="hero-v2__text">{{ section.settings.text }}</p>
    {%- endif -%}

    <div class="hero-v2__actions">
      {%- if section.settings.btn_1_text != blank -%}
        <a href="{{ section.settings.btn_1_link }}" class="btn-primary">
          {{ section.settings.btn_1_text }}
        </a>
      {%- endif -%}
      
      {%- if section.settings.btn_2_text != blank -%}
        <a href="{{ section.settings.btn_2_link }}" class="btn-secondary">
          {{ section.settings.btn_2_text }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Section V2",
  "settings": [
    {
      "type": "text",
      "id": "video_url",
      "label": "Background Video URL (MP4)",
      "info": "Overrides image if provided."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 70,
      "label": "Overlay Opacity"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "The Future of Skin Rituals.",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "text",
      "default": "Experience the ultimate clinical-grade microcurrent lift. Visible results in 5 minutes.",
      "label": "DescriptionText"
    },
    {
      "type": "text",
      "id": "btn_1_text",
      "default": "SHOP THE DEVICE",
      "label": "Primary Button Label"
    },
    {
      "type": "url",
      "id": "btn_1_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "btn_2_text",
      "default": "LEARN THE SCIENCE",
      "label": "Secondary Button Label"
    },
    {
      "type": "url",
      "id": "btn_2_link",
      "label": "Secondary Button Link"
    }
  ],
  "presets": [
    {
      "name": "Hero Section V2"
    }
  ]
}
{% endschema %}
