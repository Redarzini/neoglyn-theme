{%- style -%}
.before-after-v2 {
  padding: {{ section.settings.padding_top }}px 2rem {{ section.settings.padding_bottom }}px;
  background-color: var(--color-background);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.before-after-v2__header {
  text-align: center;
  max-width: 800px;
  margin-bottom: 3rem;
}

.before-after-v2__title {
  font-family: var(--font-heading-family);
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 900;
  color: var(--color-foreground);
  margin-bottom: 1rem;
}

.before-after-v2__text {
  color: var(--color-text-muted);
  font-size: 1.125rem;
  line-height: 1.6;
}

.before-after-v2__container {
  position: relative;
  width: 100%;
  max-width: {{ section.settings.max_width }}px;
  aspect-ratio: {{ section.settings.aspect_ratio }};
  overflow: hidden;
  border-radius: 12px;
  box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  user-select: none;
}

.before-after-v2__img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  pointer-events: none;
}

.before-after-v2__img--after {
  z-index: 1;
}

.before-after-v2__img--before {
  z-index: 2;
  clip-path: polygon(0 0, 50% 0, 50% 100%, 0 100%);
}

.before-after-v2__slider {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  cursor: ew-resize;
  z-index: 5;
}

.before-after-v2__handle {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  width: 2px;
  background-color: var(--color-accent);
  z-index: 4;
  transform: translateX(-50%);
  pointer-events: none;
}

.before-after-v2__handle-btn {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 48px;
  height: 48px;
  background-color: var(--color-accent);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 10px rgba(0,0,0,0.3);
  color: var(--color-primary);
}

.before-after-v2__labels {
  position: absolute;
  bottom: 1rem;
  width: 100%;
  display: flex;
  justify-content: space-between;
  padding: 0 2rem;
  z-index: 3;
  pointer-events: none;
}

.before-after-v2__label {
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  padding: 0.5rem 1rem;
  border-radius: 9999px;
  font-weight: 700;
  font-size: 0.875rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--color-foreground);
  border: 1px solid var(--glass-border);
}

{%- endstyle -%}

<section class="before-after-v2" id="BeforeAfter-{{ section.id }}">
  <div class="before-after-v2__header">
    <h2 class="before-after-v2__title">{{ section.settings.heading }}</h2>
    {%- if section.settings.text != blank -%}
      <p class="before-after-v2__text">{{ section.settings.text }}</p>
    {%- endif -%}
  </div>

  <div class="before-after-v2__container">
    {%- if section.settings.image_after != blank -%}
      {{ section.settings.image_after | image_url: width: 2000 | image_tag: class: 'before-after-v2__img before-after-v2__img--after' }}
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'before-after-v2__img before-after-v2__img--after' }}
    {%- endif -%}

    {%- if section.settings.image_before != blank -%}
      {{ section.settings.image_before | image_url: width: 2000 | image_tag: class: 'before-after-v2__img before-after-v2__img--before', id: 'img-before-' | append: section.id }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'before-after-v2__img before-after-v2__img--before' }}
    {%- endif -%}

    <div class="before-after-v2__labels">
      <span class="before-after-v2__label">Before</span>
      <span class="before-after-v2__label">After</span>
    </div>

    <div class="before-after-v2__handle" id="handle-{{ section.id }}">
      <div class="before-after-v2__handle-btn">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left:-8px;"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </div>
    </div>

    <input type="range" min="0" max="100" value="50" class="before-after-v2__slider" id="slider-{{ section.id }}" aria-label="Percentage of before photo shown">
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const slider = document.getElementById('slider-{{ section.id }}');
    const beforeImg = document.getElementById('img-before-{{ section.id }}');
    const handle = document.getElementById('handle-{{ section.id }}');

    if(!slider || !beforeImg || !handle) return;

    slider.addEventListener('input', (e) => {
      const val = e.target.value;
      beforeImg.style.clipPath = `polygon(0 0, ${val}% 0, ${val}% 100%, 0 100%)`;
      handle.style.left = `${val}%`;
    });
  });
</script>

{% schema %}
{
  "name": "Before & After V2",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Clinically Proven Results.",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "text",
      "default": "See the visible lift and contouring effects after just one 5-minute treatment.",
      "label": "Description"
    },
    {
      "type": "image_picker",
      "id": "image_before",
      "label": "Before Image"
    },
    {
      "type": "image_picker",
      "id": "image_after",
      "label": "After Image"
    },
    {
      "type": "text",
      "id": "aspect_ratio",
      "default": "16/9",
      "label": "Aspect Ratio (e.g., 16/9 or 4/3)"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 600,
      "max": 1400,
      "step": 100,
      "default": 1000,
      "unit": "px",
      "label": "Maximum Width"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Before & After V2"
    }
  ]
}
{% endschema %}
