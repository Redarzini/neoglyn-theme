{{ 'neoglyn-how-to-use.css' | asset_url | stylesheet_tag }}

<div class="neoglyn-how-to-use page-width section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="neoglyn-how-to-use__container">
    <div class="neoglyn-how-to-use__header">
      <h3 class="neoglyn-how-to-use__title">{{ section.settings.heading }}</h3>
      <p class="neoglyn-how-to-use__subtitle text-primary">{{ section.settings.subtitle }}</p>
    </div>
    
    <div class="neoglyn-how-to-use__grid">
      {% for block in section.blocks %}
        <div class="neoglyn-how-to-use__step" {{ block.shopify_attributes }}>
          <div class="neoglyn-how-to-use__number">0{{ forloop.index }}</div>
          <h4 class="neoglyn-how-to-use__step-title">{{ block.settings.title }}</h4>
          <p class="neoglyn-how-to-use__step-text">{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Neoglyn How to Use",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#001F3F"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Neoglyn Ritual"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Simplicity meets Clinical Excellence"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Neoglyn How to Use",
      "blocks": [
        { "type": "step", "settings": { "title": "Preparation", "text": "Cleanse skin thoroughly and apply the Silver Conductive Gel to the targeted treatment zones." } },
        { "type": "step", "settings": { "title": "Treatment", "text": "Glide the flagship device in upward circular motions for 5-10 minutes across face and neck." } },
        { "type": "step", "settings": { "title": "Results", "text": "Massage remaining serum into the skin. Repeat 3 times weekly for transformative results." } }
      ]
    }
  ]
}
{% endschema %}
