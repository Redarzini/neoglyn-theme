<div class="neoglyn-policy page-width section-{{ section.id }}-padding bg-white dark:bg-background-dark text-midnight dark:text-slate-100 font-display min-h-screen">
  <div class="max-w-[800px] mx-auto py-20 lg:py-32 px-6 lg:px-0">
    
    <div class="mb-16">
      <span class="text-primary font-bold tracking-[0.2em] uppercase text-xs mb-4 block">{{ section.settings.tagline }}</span>
      <h1 class="text-4xl lg:text-5xl font-extrabold tracking-tight text-midnight dark:text-white mb-6">{{ section.settings.heading | default: page.title }}</h1>
      <p class="text-lg text-midnight/60 dark:text-slate-400">Last updated: {{ section.settings.last_updated }}</p>
    </div>

    <div class="prose prose-lg prose-slate dark:prose-invert max-w-none text-midnight/80 dark:text-slate-300 [&>h2]:text-midnight dark:[&>h2]:text-white [&>h2]:font-bold [&>h2]:mt-12 [&>h2]:mb-4 [&>p]:mb-6 [&>ul]:list-disc [&>ul]:pl-6 [&>ul]:mb-6 [&>li]:mb-2">
      {{ section.settings.policy_content | default: page.content }}
    </div>
    
  </div>
</div>

{% schema %}
{
  "name": "Neoglyn Policy",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Legal Information"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Policy Heading",
      "info": "Leave blank to use the page title automatically."
    },
    {
      "type": "text",
      "id": "last_updated",
      "label": "Last Updated Date",
      "default": "October 24, 2024"
    },
    {
      "type": "richtext",
      "id": "policy_content",
      "label": "Policy Content",
      "info": "Leave blank to use the page's rich text content automatically."
    }
  ],
  "presets": [
    {
      "name": "Neoglyn Policy"
    }
  ]
}
{% endschema %}
