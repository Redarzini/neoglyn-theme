{{ 'neoglyn-hero.css' | asset_url | stylesheet_tag }}

<section class="neoglyn-hero section-{{ section.id }}-padding bg-background-light">
  <div class="neoglyn-hero__container page-width">
    
    <div class="neoglyn-hero__images">
      <div class="neoglyn-hero__image-grid">
        <div class="neoglyn-hero__image neoglyn-hero__image--before" {% if section.settings.image_before %}style="background-image: url('{{ section.settings.image_before | image_url: width: 800 }}');"{% endif %} aria-label="{{ section.settings.badge_1_text }}">
          <span class="neoglyn-hero__badge neoglyn-hero__badge--midnight">{{ section.settings.badge_1_text }}</span>
        </div>
        <div class="neoglyn-hero__image neoglyn-hero__image--after" {% if section.settings.image_after %}style="background-image: url('{{ section.settings.image_after | image_url: width: 800 }}');"{% endif %} aria-label="{{ section.settings.badge_2_text }}">
          <span class="neoglyn-hero__badge neoglyn-hero__badge--primary">{{ section.settings.badge_2_text }}</span>
        </div>
      </div>
      <div class="neoglyn-hero__overlay"></div>
    </div>

    <div class="neoglyn-hero__content">
      <div class="neoglyn-hero__content-inner">
        <span class="neoglyn-hero__subtitle text-primary">{{ section.settings.subtitle }}</span>
        <h1 class="neoglyn-hero__title text-midnight">{{ section.settings.heading }}</h1>
        <p class="neoglyn-hero__text text-slate">{{ section.settings.text }}</p>
      </div>

      <div class="neoglyn-hero__actions">
        {% if section.settings.button_label_1 != blank %}
          <a href="{{ section.settings.button_link_1 }}" class="btn btn--primary">
            {{ section.settings.button_label_1 }}
          </a>
        {% endif %}
        {% if section.settings.button_label_2 != blank %}
          <a href="{{ section.settings.button_link_2 }}" class="btn btn--secondary">
            {{ section.settings.button_label_2 }}
          </a>
        {% endif %}
      </div>

      <div class="neoglyn-hero__social-proof border-top-surface">
        <div class="neoglyn-hero__avatars">
          {% for block in section.blocks %}
            {% if block.type == 'avatar' %}
              <div class="neoglyn-hero__avatar" {% if block.settings.image %}style="background-image: url('{{ block.settings.image | image_url: width: 100 }}')"{% endif %}></div>
            {% endif %}
          {% endfor %}
        </div>
        <p class="neoglyn-hero__social-text">{{ section.settings.social_text }}</p>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Neoglyn Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_before",
      "label": "Before Image"
    },
    {
      "type": "image_picker",
      "id": "image_after",
      "label": "After Image"
    },
    {
      "type": "text",
      "id": "badge_1_text",
      "label": "Badge 1 Text",
      "default": "Before"
    },
    {
      "type": "text",
      "id": "badge_2_text",
      "label": "Badge 2 Text",
      "default": "4 Weeks After"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Premium Home Care"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Professional-Grade Luxury, Designed for Your Daily Ritual"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Experience the transformative power of Neoglyn. Our artisan-crafted formulas bring the pinnacle of clinical excellence into the comfort of your home, curating a radiant future for your skin."
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Primary Button Label",
      "default": "Shop Best Sellers"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary Button Label",
      "default": "Discover the Ritual"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary Button Link"
    },
    {
      "type": "text",
      "id": "social_text",
      "label": "Social Proof Text",
      "default": "Join 50,000+ happy customers"
    }
  ],
  "blocks": [
    {
      "type": "avatar",
      "name": "Social Avatar",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Avatar Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Neoglyn Hero",
      "category": "Image",
      "blocks": [
        { "type": "avatar" },
        { "type": "avatar" },
        { "type": "avatar" }
      ]
    }
  ]
}
{% endschema %}
