{{ 'neoglyn-dashboard.css' | asset_url | stylesheet_tag }}

<div class="neoglyn-dashboard flex min-h-screen bg-background-light text-midnight section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  
  <!-- Sidebar Navigation -->
  <aside class="neoglyn-dashboard__sidebar w-64 border-r border-slate-200 bg-white flex flex-col justify-between p-6 hidden md:flex">
    <div class="space-y-8">
      <div class="flex items-center gap-3">
        <div class="h-10 w-10 rounded-full bg-primary-10 flex items-center justify-center">
          <span class="material-symbols-outlined text-primary">spa</span>
        </div>
        <div>
          <h1 class="text-midnight text-lg font-bold leading-none">{{ section.settings.sidebar_title }}</h1>
          <p class="text-slate-500 text-xs font-medium uppercase tracking-wider">{{ section.settings.member_tier }}</p>
        </div>
      </div>
      
      <nav class="space-y-2">
        {% for block in section.blocks %}
          {% if block.type == 'nav_link' %}
             <a class="flex items-center gap-3 px-3 py-2 rounded-lg {% if forloop.first %}bg-primary-10 text-midnight font-semibold{% else %}text-slate-600 hover:bg-slate-50 transition-colors{% endif %}" href="{{ block.settings.link }}">
              <span class="material-symbols-outlined {% if forloop.first %}text-primary{% endif %}">{{ block.settings.icon }}</span>
              <span>{{ block.settings.title }}</span>
            </a>
          {% endif %}
        {% endfor %}
      </nav>
    </div>
    
    <div class="bg-slate-50 rounded-xl p-4 space-y-3 mt-8">
      <p class="text-xs font-bold text-slate-500 uppercase">{{ section.settings.plan_label }}</p>
      <p class="text-sm font-semibold text-midnight">{{ section.settings.plan_name }}</p>
      <button class="w-full btn btn--primary py-2 rounded-lg font-bold text-sm">
        {{ section.settings.upgrade_button_text }}
      </button>
    </div>
  </aside>

  <!-- Main Content Area -->
  <main class="neoglyn-dashboard__main flex-1 p-6 lg:p-12 overflow-y-auto w-full">
    
    <!-- Header Section -->
    <header class="mb-10 flex justify-between items-start flex-col sm:flex-row gap-4">
      <div>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-midnight tracking-tight">Welcome back, {{ customer.first_name | default: 'Member' }}</h2>
        <p class="text-slate-500 mt-2 text-sm sm:text-lg">{{ section.settings.welcome_message }}</p>
      </div>
      <div class="flex items-center gap-4 self-end sm:self-auto">
        <button class="p-2 rounded-full border border-slate-200 hover:bg-white transition-colors" aria-label="Notifications">
          <span class="material-symbols-outlined text-slate-600">notifications</span>
        </button>
        <div class="h-12 w-12 rounded-full border-2 border-primary p-0.5" aria-hidden="true">
          <div class="h-full w-full rounded-full bg-cover bg-center" style="background-image: url('{{ section.settings.profile_image | image_url: width: 100 | default: "https://cdn.shopify.com/s/files/1/0533/2089/files/placeholder-images-person.png" }}')"></div>
        </div>
      </div>
    </header>

    <!-- Quick Stats -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
      
      <!-- Points -->
      <div class="bg-white p-6 rounded-xl border border-slate-100 shadow-sm flex flex-col">
        <div class="flex justify-between items-center mb-4">
          <span class="text-slate-500 font-medium">Reward Points</span>
          <div class="bg-primary-10 p-2 rounded-lg">
            <span class="material-symbols-outlined text-primary">stars</span>
          </div>
        </div>
        <div class="flex items-baseline gap-2">
          <span class="text-3xl font-bold text-midnight">2,450</span>
          <span class="text-sm font-bold text-emerald-600">+150 pts</span>
        </div>
        <p class="text-xs text-slate-400 mt-2">Earned 12 pts per $1 spent</p>
      </div>

      <!-- Tier Status -->
      <div class="bg-white p-6 rounded-xl border border-slate-100 shadow-sm flex flex-col">
        <div class="flex justify-between items-center mb-4">
          <span class="text-slate-500 font-medium">Tier Status</span>
          <div class="bg-primary-10 p-2 rounded-lg">
            <span class="material-symbols-outlined text-primary">shutter_speed</span>
          </div>
        </div>
        <div class="flex items-baseline gap-2">
          <span class="text-3xl font-bold text-midnight">85%</span>
          <span class="text-sm font-bold text-emerald-600">+5%</span>
        </div>
        <div class="w-full bg-slate-100 h-2 rounded-full mt-4">
          <div class="bg-primary h-2 rounded-full" style="width: 85%"></div>
        </div>
        <p class="text-xs text-slate-400 mt-2">550 pts until Platinum Tier</p>
      </div>

      <!-- Orders -->
      <div class="bg-white p-6 rounded-xl border border-slate-100 shadow-sm flex flex-col md:col-span-2 lg:col-span-1">
        <div class="flex justify-between items-center mb-4">
          <span class="text-slate-500 font-medium">Total Orders</span>
          <div class="bg-primary-10 p-2 rounded-lg">
            <span class="material-symbols-outlined text-primary">shopping_bag</span>
          </div>
        </div>
        <div class="flex items-baseline gap-2">
          <span class="text-3xl font-bold text-midnight">{{ customer.orders_count | default: '14' }}</span>
          <span class="text-sm font-bold text-slate-400">Lifetime</span>
        </div>
        <p class="text-xs text-slate-400 mt-2">Last order: {% if customer.last_order %}{{ customer.last_order.created_at | date: "%b %d, %Y" }}{% else %}12 days ago{% endif %}</p>
      </div>

    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      
      <!-- Skin Profile Summary -->
      <section class="space-y-4">
        <h3 class="text-xl font-bold text-midnight flex items-center gap-2">
          <span class="material-symbols-outlined text-primary">dermatology</span>
          {{ section.settings.profile_summary_title }}
        </h3>
        
        <div class="bg-white rounded-xl border border-slate-100 shadow-sm overflow-hidden flex flex-col sm:flex-row">
          <div class="flex-1 p-6 space-y-4">
            <div>
              <h4 class="text-lg font-bold text-midnight leading-none">{{ section.settings.skin_type }}</h4>
              <p class="text-slate-500 text-sm mt-1">{{ section.settings.skin_details }}</p>
            </div>
            <div class="space-y-2">
              <p class="text-xs font-bold text-slate-400 uppercase">Primary Concerns</p>
              <div class="flex flex-wrap gap-2">
                 {% for block in section.blocks %}
                   {% if block.type == 'concern' %}
                     <span class="px-2 py-1 bg-slate-50 rounded text-xs font-medium text-midnight border border-slate-100">{{ block.settings.title }}</span>
                   {% endif %}
                 {% endfor %}
              </div>
            </div>
            <button class="flex items-center gap-2 text-sm font-bold text-primary hover:underline underline-offset-4">
              Update Profile <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </button>
          </div>
          <div class="w-full sm:w-48 h-48 sm:h-auto bg-cover bg-center" style="background-image: url('{{ section.settings.profile_bg_image | image_url: width: 400 | default: "https://lh3.googleusercontent.com/aida-public/AB6AXuDnhwQgyDevEak3hJ_03adFaK9yQzsayCw6UUob5nMNmfYzDnCOC9GXdQe2CWBTSjG3K3bD1tp7MPRi46lA3_haSr_Rf9X5znlETFalw1lLSRrUqUVU7L_rCFucaWeGFmX3vlFoQZr8iIDZYJhS25kHc5SrTdL5KC0WXkbwPlMlvbRPFmnbxH8FFDqfbni0UdMOwFsnYM553uGEsIxEsabJs8-UNV-E50238Y84rokXOOj0wRp9rY8WutMedf0wSh8dsukEYW9W6kM" }}')"></div>
        </div>
      </section>

      <!-- Recent Order History -->
      <section class="space-y-4">
        <h3 class="text-xl font-bold text-midnight flex items-center gap-2">
          <span class="material-symbols-outlined text-primary">receipt_long</span>
          Recent Orders
        </h3>
        
        <div class="bg-white rounded-xl border border-slate-100 shadow-sm overflow-hidden overflow-x-auto">
          <table class="w-full text-left border-collapse min-w-[400px]">
            <thead>
              <tr class="bg-slate-50 text-slate-500 text-xs font-bold uppercase tracking-wider">
                <th class="px-6 py-3">Order ID</th>
                <th class="px-6 py-3">Date</th>
                <th class="px-6 py-3">Status</th>
                <th class="px-6 py-3 text-right">Amount</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
               {% if customer.orders.size > 0 %}
                 {% for order in customer.orders limit: 3 %}
                  <tr>
                    <td class="px-6 py-4 text-sm font-semibold">{{ order.name }}</td>
                    <td class="px-6 py-4 text-sm text-slate-500">{{ order.created_at | date: "%b %d, %Y" }}</td>
                    <td class="px-6 py-4 text-sm">
                      <span class="px-2 py-1 bg-emerald-50 text-emerald-600 rounded-full text-xs font-bold">{{ order.fulfillment_status_label }}</span>
                    </td>
                    <td class="px-6 py-4 text-sm font-bold text-right">{{ order.total_price | money }}</td>
                  </tr>
                 {% endfor %}
               {% else %}
                 <!-- Placeholder Data for Design -->
                  <tr>
                    <td class="px-6 py-4 text-sm font-semibold">#NG-98231</td>
                    <td class="px-6 py-4 text-sm text-slate-500">Oct 24, 2023</td>
                    <td class="px-6 py-4 text-sm">
                      <span class="px-2 py-1 bg-emerald-50 text-emerald-600 rounded-full text-xs font-bold">Delivered</span>
                    </td>
                    <td class="px-6 py-4 text-sm font-bold text-right">$124.00</td>
                  </tr>
                  <tr>
                    <td class="px-6 py-4 text-sm font-semibold">#NG-97554</td>
                    <td class="px-6 py-4 text-sm text-slate-500">Sep 12, 2023</td>
                    <td class="px-6 py-4 text-sm">
                      <span class="px-2 py-1 bg-emerald-50 text-emerald-600 rounded-full text-xs font-bold">Delivered</span>
                    </td>
                    <td class="px-6 py-4 text-sm font-bold text-right">$89.50</td>
                  </tr>
               {% endif %}
            </tbody>
          </table>
          <div class="px-6 py-3 border-t border-slate-100 text-center">
            <a href="{{ routes.account_url }}" class="text-sm font-bold text-slate-500 hover:text-midnight">View All History</a>
          </div>
        </div>
      </section>
      
    </div>

    <!-- Recommended for you (Dynamic Product Pull) -->
    <section class="mt-12 space-y-4">
      <h3 class="text-xl font-bold text-midnight">{{ section.settings.recommendation_title }}</h3>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {% if collections['all'].products.size > 0 %}
          {% for product in collections['all'].products limit: 4 %}
            <div class="bg-white rounded-xl border border-slate-100 p-4 shadow-sm group">
              <a href="{{ product.url }}" class="block">
                <div class="aspect-square bg-slate-50 rounded-lg mb-4 bg-cover bg-center overflow-hidden" style="background-image: url('{{ product.featured_image | image_url: width: 400 }}')"></div>
                <h5 class="font-bold text-midnight text-sm">{{ product.title }}</h5>
                <p class="text-slate-500 text-xs">{{ product.type | default: 'Best Seller' }}</p>
                <div class="flex justify-between items-center mt-3">
                  <span class="font-bold text-midnight">{{ product.price | money }}</span>
                  <button class="h-8 w-8 rounded-full bg-midnight text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity" aria-label="Add {{ product.title }} to cart">
                    <span class="material-symbols-outlined text-sm">add</span>
                  </button>
                </div>
              </a>
            </div>
          {% endfor %}
        {% else %}
           <!-- Safe Fallback if no products -->
           <div class="bg-white rounded-xl border border-slate-100 p-4 shadow-sm">
               <p class="text-sm">Populate your store with products to see recommendations here.</p>
           </div>
        {% endif %}
      </div>
    </section>

  </main>
</div>

{% schema %}
{
  "name": "Neoglyn Dashboard",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F6F8F7"
    },
    {
       "type": "header",
       "content": "Sidebar Settings"
    },
    {
      "type": "text",
      "id": "sidebar_title",
      "label": "Sidebar Title",
      "default": "Neoglyn Club"
    },
    {
      "type": "text",
      "id": "member_tier",
      "label": "Member Tier Script",
      "default": "Premium Member"
    },
    {
      "type": "text",
      "id": "plan_label",
      "label": "Plan Label",
      "default": "Current Plan"
    },
    {
      "type": "text",
      "id": "plan_name",
      "label": "Plan Name",
      "default": "Club Enthusiast"
    },
    {
      "type": "text",
      "id": "upgrade_button_text",
      "label": "Upgrade Button Text",
      "default": "Upgrade Plan"
    },
    {
       "type": "header",
       "content": "Main Content Settings"
    },
    {
      "type": "text",
      "id": "welcome_message",
      "label": "Welcome Message",
      "default": "Manage your Neoglyn skin care journey and rewards here."
    },
    {
      "type": "image_picker",
      "id": "profile_image",
      "label": "User Profile Avatar (Placeholder)"
    },
    {
      "type": "text",
      "id": "profile_summary_title",
      "label": "Profile Summary Title",
      "default": "Skin Profile Summary"
    },
    {
      "type": "text",
      "id": "skin_type",
      "label": "Default Skin Type",
      "default": "Combination Skin"
    },
    {
      "type": "text",
      "id": "skin_details",
      "label": "Default Skin Details",
      "default": "Sensitivity: Low | Hydration: Moderate"
    },
    {
      "type": "image_picker",
      "id": "profile_bg_image",
      "label": "Profile Card Image"
    },
    {
      "type": "text",
      "id": "recommendation_title",
      "label": "Recommendations Title",
      "default": "Recommended for your Routine"
    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Navigation Link",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Link Title"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Material Icon ID",
          "default": "dashboard"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        }
      ]
    },
    {
      "type": "concern",
      "name": "Skin Concern Tag",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Concern Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Neoglyn Dashboard",
      "blocks": [
        { "type": "nav_link", "settings": { "title": "Dashboard", "icon": "dashboard", "link": "#" } },
        { "type": "nav_link", "settings": { "title": "Skin Profile", "icon": "face", "link": "#" } },
        { "type": "nav_link", "settings": { "title": "My Rewards", "icon": "featured_seasonal_and_gifts", "link": "#" } },
        { "type": "nav_link", "settings": { "title": "Order History", "icon": "history", "link": "#" } },
        { "type": "nav_link", "settings": { "title": "Settings", "icon": "settings", "link": "#" } },
        { "type": "concern", "settings": { "title": "Anti-Aging" } },
        { "type": "concern", "settings": { "title": "Pore Refinement" } }
      ]
    }
  ]
}
{% endschema %}
