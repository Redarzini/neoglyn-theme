{{ 'neoglyn-press.css' | asset_url | stylesheet_tag }}

<div class="neoglyn-press bg-midnight dark:bg-black text-white font-display min-h-screen">
  
  <div class="max-w-[1200px] mx-auto py-24 px-6 lg:px-10">
    <div class="flex flex-col items-center text-center mb-20 gap-6">
       <span class="text-primary font-bold tracking-[0.3em] uppercase text-xs">{{ section.settings.tagline }}</span>
       <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-white max-w-3xl">{{ section.settings.heading }}</h1>
       <p class="text-white/60 text-lg max-w-2xl">{{ section.settings.text }}</p>
    </div>

    <!-- Featured Press -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-24">
      <div class="aspect-video bg-white/5 rounded-3xl overflow-hidden border border-white/10 relative group">
        <img src="{{ section.settings.featured_image | image_url: width: 1000 | default: 'https://lh3.googleusercontent.com/aida-public/AB6AXuDt1xsn3aFRXJigcRGhoCw1deB21Nuo3WxX3Il6VwDAKTs2tYMWGJ0Sc-Tw-QDOiGFFfdfU7d7mnAd93XrB3KDIJrIYz3-4fk_SNIIIepugn_CFTpxml9-V01G42KVoxUqJ7PEa4bhpBwWj9GI56kclBy8rbHcEJnJDXBAxZpzgjBfX9E3cK7l5NvFZ4QoUaUKQGOKvPCWcVxlJbqxLV7d-ZvvurqiKhY2PjiKTjamQQhskaqtZjA-_B_8oJBhmgRImopG2IQDMZww' }}" alt="Featured Press" class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity duration-500">
      </div>
      <div class="flex flex-col justify-center gap-8">
        <div class="h-12 flex items-center text-2xl font-bold font-serif italic text-white/50">"Vogue"</div>
        <h2 class="text-3xl md:text-4xl font-bold text-white leading-tight">
          "The beauty tech device that is rendering professional facials completely obsolete."
        </h2>
        <a href="#" class="inline-flex items-center gap-2 text-primary font-bold uppercase tracking-widest text-xs hover:text-white transition-colors">
          Read the full article <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
        </a>
      </div>
    </div>

    <!-- Press Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for block in section.blocks %}
        {% if block.type == 'press_mention' %}
          <div class="bg-white/5 border border-white/10 rounded-2xl p-8 flex flex-col justify-between gap-8 hover:bg-white/10 transition-colors">
            <h3 class="text-xl font-bold text-white mb-2 leading-snug">"{{ block.settings.quote }}"</h3>
            <div class="flex items-center justify-between mt-4">
              <span class="font-bold text-primary uppercase tracking-widest text-xs">{{ block.settings.publication }}</span>
              <span class="text-white/40 text-xs">{{ block.settings.date }}</span>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <!-- Download Brand Assets -->
    <div class="mt-32 p-12 lg:p-16 rounded-3xl bg-white text-midnight flex flex-col md:flex-row items-center justify-between gap-10">
      <div class="flex flex-col gap-4 max-w-xl">
        <h2 class="text-3xl font-extrabold tracking-tight">Media & Brand Assets</h2>
        <p class="text-midnight/60 text-lg">Download high-resolution product imagery, logos, and our official brand guidelines for editorial use.</p>
      </div>
      <a href="{{ section.settings.download_link }}" class="flex-shrink-0 bg-primary text-midnight px-8 py-4 rounded-full font-bold uppercase tracking-widest text-sm hover:brightness-95 transition-all flex items-center gap-3">
        Download Zip <span class="material-symbols-outlined text-[18px]">download</span>
      </a>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Neoglyn Press Kit",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "In The Press"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The beauty industry is talking."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Discover what top editors, estheticians, and beauty critics are saying about the Neoglyn revolution."
    },
    {
      "type": "image_picker",
      "id": "featured_image",
      "label": "Featured Press Image"
    },
    {
      "type": "url",
      "id": "download_link",
      "label": "Brand Assets Download Link"
    }
  ],
  "blocks": [
    {
      "type": "press_mention",
      "name": "Press Mention",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "A masterclass in industrial design meeting skincare efficacy."
        },
        {
          "type": "text",
          "id": "publication",
          "label": "Publication Name",
          "default": "Allure"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "Oct 2024"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Neoglyn Press Kit",
      "blocks": [
        { "type": "press_mention", "settings": { "quote": "A masterclass in industrial design meeting skincare efficacy.", "publication": "Allure", "date": "Oct 2024" } },
        { "type": "press_mention", "settings": { "quote": "The microcurrent technology is incredibly potent yet shockingly gentle.", "publication": "Harper's Bazaar", "date": "Sep 2024" } },
        { "type": "press_mention", "settings": { "quote": "终于有了一款既好看又好用的美容仪 (Finally a beauty device perfectly combining aesthetics and function)", "publication": "Elle China", "date": "Aug 2024" } }
      ]
    }
  ]
}
{% endschema %}
