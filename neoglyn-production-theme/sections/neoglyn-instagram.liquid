{{ 'neoglyn-instagram.css' | asset_url | stylesheet_tag }}

<div class="neoglyn-instagram page-width section-{{ section.id }}-padding">
  <div class="neoglyn-instagram__header">
    <span class="neoglyn-instagram__subtitle text-primary">{{ section.settings.subtitle }}</span>
    <h2 class="neoglyn-instagram__title text-midnight">{{ section.settings.heading }}</h2>
    <p class="neoglyn-instagram__text">{{ section.settings.text }}</p>
  </div>

  <div class="neoglyn-instagram__grid">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link }}" class="neoglyn-instagram__item" {{ block.shopify_attributes }}>
        <div class="neoglyn-instagram__image" style="background-image: url('{{ block.settings.image | image_url: width: 600 }}');" aria-label="Instagram post"></div>
        <div class="neoglyn-instagram__overlay">
           {% render 'icon-heart' %}
        </div>
      </a>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Neoglyn Instagram",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Community"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Glow with Neoglyn"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Follow us @neoglyn_beauty for daily tips and results"
    }
  ],
  "blocks": [
    {
      "type": "instagram_post",
      "name": "Instagram Post",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Neoglyn Instagram",
      "blocks": [
        { "type": "instagram_post" },
        { "type": "instagram_post" },
        { "type": "instagram_post" },
        { "type": "instagram_post" }
      ]
    }
  ]
}
{% endschema %}
